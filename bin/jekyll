#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_prefix="${JEKYLL_ENV_PREFIX:-$HOME/.local/share/mamba/envs/fritschek-jekyll}"

if [[ ! -x "$env_prefix/bin/bundle" ]]; then
  cat >&2 <<MSG
Missing Jekyll environment at:
  $env_prefix

Create it with:
  micromamba create -y -n fritschek-jekyll -c conda-forge ruby=3.3 libxcrypt c-compiler cxx-compiler make
  JEKYLL_ENV_PREFIX="$env_prefix" ./bin/jekyll bundle install
MSG
  exit 1
fi

export PATH="$env_prefix/bin:$PATH"
export LD_LIBRARY_PATH="$env_prefix/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"

cd "$repo_root"

if [[ "${1:-}" == "bundle" ]]; then
  shift
  exec bundle "$@"
fi

exec bundle exec jekyll "$@"
